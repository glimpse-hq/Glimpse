{
  "name": "glimpse",
  "private": true,
  "version": "0.9.8",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "build": "bun ./node_modules/typescript/lib/tsc.js && bun ./node_modules/vite/bin/vite.js build",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "preview": "bun ./node_modules/vite/bin/vite.js preview",
    "tauri": "bun ./scripts/tauri.mjs",
    "lint": "bun ./node_modules/eslint/bin/eslint.js src/",
    "lint:ci": "bun ./node_modules/eslint/bin/eslint.js src/ --max-warnings 0",
    "format": "prettier --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:check": "prettier --check . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check"
  },
  "dependencies": {
    "@lingui/core": "^6.3.0",
    "@lingui/react": "^6.3.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@xstate/react": "^6.1.0",
    "framer-motion": "^12.40.0",
    "howler": "^2.2.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github": "^12.0.0",
    "tauri-plugin-macos-permissions-api": "^2.3.0",
    "xstate": "^5.32.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@lingui/babel-plugin-lingui-macro": "^6.3.0",
    "@lingui/cli": "^6.3.0",
    "@lingui/format-po": "^6.3.0",
    "@lingui/vite-plugin": "^6.3.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-boundaries": "^6.0.2",
    "prettier": "3.7.4",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
